\newlabel{sec:probe}{{5}{5}{Result II: The Causal Probe---the Written Chain Is Not Load-Bearing}{section.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Accuracy $\perp $ written-chain faithfulness.} CoT distillation lifts ChartQA accuracy by $+6.5$--$7.0\%$ (McNemar $p\!\le \!.002$; horizontal arrows), yet the causal CoT metric stays on the $F\!\approx \!0$ band ($F=\text  {flip}_{\textsc  {corrupt}}-\text  {flip}_{\textsc  {shuffle}}$): corrupting a numeric intermediate flips the answer no more than shuffling the CoT. This is a conservative harsh-control criterion: \textsc  {shuffle}{} disrupts order without injecting any target value, so $F\!\leq \!0$ means the falsified intermediate contributes no extra flip beyond order/format noise. A targeted ChartQA 8B \textsc  {local-num}{} replication below checks the same claim under a gentler no-target perturbation. Hollow markers show image-masked controls. $F$ is measured on the same SFT student used for the corresponding probe; the tabular intervals and corrected tests in Table~\ref {tab:probe} are regenerated by \texttt  {scripts/faithfulness\_stats.py}.}}{6}{figure.caption.14}\protected@file@percent }
\newlabel{fig:decoupling}{{2}{6}{\textbf {Accuracy $\perp $ written-chain faithfulness.} CoT distillation lifts ChartQA accuracy by $+6.5$--$7.0\%$ (McNemar $p\!\le \!.002$; horizontal arrows), yet the causal CoT metric stays on the $F\!\approx \!0$ band ($F=\text {flip}_{\corrupt }-\text {flip}_{\shuffle }$): corrupting a numeric intermediate flips the answer no more than shuffling the CoT. This is a conservative harsh-control criterion: \shuffle {} disrupts order without injecting any target value, so $F\!\leq \!0$ means the falsified intermediate contributes no extra flip beyond order/format noise. A targeted ChartQA 8B \localnum {} replication below checks the same claim under a gentler no-target perturbation. Hollow markers show image-masked controls. $F$ is measured on the same SFT student used for the corresponding probe; the tabular intervals and corrected tests in Table~\ref {tab:probe} are regenerated by \texttt {scripts/faithfulness\_stats.py}}{figure.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Causal CoT-intermediate probe on chart/table SFT cells. Flow is raw $n{=}400$ to probe-eligible correct+CoT cases, with \textsc  {corrupt}{}/\textsc  {shuffle}{} denominators in parentheses. $F=\text  {flip}_{\textsc  {corrupt}}-\text  {flip}_{\textsc  {shuffle}}$; $p_H$ is Holm-adjusted for the one-sided load-bearing test. Snap/follow are rates after \textsc  {corrupt}{} with Wilson 95\% CIs.}}{7}{table.caption.15}\protected@file@percent }
\newlabel{tab:probe}{{1}{7}{Causal CoT-intermediate probe on chart/table SFT cells. Flow is raw $n{=}400$ to probe-eligible correct+CoT cases, with \corrupt {}/\shuffle {} denominators in parentheses. $F=\text {flip}_{\corrupt }-\text {flip}_{\shuffle }$; $p_H$ is Holm-adjusted for the one-sided load-bearing test. Snap/follow are rates after \corrupt {} with Wilson 95\% CIs}{table.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {P0-5 cross-family replication.} InternVL3.5-8B is a non-Qwen VLM evaluated on the same ChartQA present-image probe protocol. This row is external-validity evidence and is reported separately from the Qwen-family SFT cells in Table~\ref {tab:probe}.}}{7}{table.caption.16}\protected@file@percent }
\newlabel{tab:crossfamily}{{2}{7}{\textbf {P0-5 cross-family replication.} InternVL3.5-8B is a non-Qwen VLM evaluated on the same ChartQA present-image probe protocol. This row is external-validity evidence and is reported separately from the Qwen-family SFT cells in Table~\ref {tab:probe}}{table.caption.16}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Selection flow and answer-eval strata.} Answer-eval strata are stable-correct / SFT-gain / SFT-loss / both-wrong on the paired $n{=}400$ accuracy run. Probe-kept strata are the same case IDs after the separate CoT-generation eligibility filter. ``No usable corrupt'' is raw cases without a usable \textsc  {corrupt}{} readout, including non-eligible cases and any eligible CoT with no corruptible numeric token. The final columns report present-condition \textsc  {corrupt}{} follow rates in the two strata most relevant to the main claim. Full masked rows, loss/wrong strata, and sensitivity bounds are in \texttt  {faithfulness\_stats.md}.}}{8}{table.caption.17}\protected@file@percent }
\newlabel{tab:selection}{{3}{8}{\textbf {Selection flow and answer-eval strata.} Answer-eval strata are stable-correct / SFT-gain / SFT-loss / both-wrong on the paired $n{=}400$ accuracy run. Probe-kept strata are the same case IDs after the separate CoT-generation eligibility filter. ``No usable corrupt'' is raw cases without a usable \corrupt {} readout, including non-eligible cases and any eligible CoT with no corruptible numeric token. The final columns report present-condition \corrupt {} follow rates in the two strata most relevant to the main claim. Full masked rows, loss/wrong strata, and sensitivity bounds are in \texttt {faithfulness\_stats.md}}{table.caption.17}{}}
